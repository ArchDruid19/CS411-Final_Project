db["items"].aggregate([
    {
      $unwind: "$Inventory.inventoryHistory"
    },
    {
      $match: {
        "itemName": "Brass Sheet",
        "Inventory.inventoryHistory.transactionDate": new Date("2025-01-19")
      }
    },
    {
      $group: {
        "_id": "$itemName",
        "sum": {$sum: "$Inventory.inventoryHistory.transactionAmmount"}
      }
    }
  ]);